<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"

    android:background="@color/off_white"
    tools:context=".MainActivity">

    <!--            lol -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/imgHistory"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_margin="2dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?attr/selectableItemBackgroundBorderless"
        android:outlineAmbientShadowColor="@color/off_white"
        android:outlineSpotShadowColor="@color/off_white"
        app:cardBackgroundColor="@color/off_white"
        app:cornerRadius="50dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:strokeColor="@color/off_white">

        <ImageView

            android:id="@+id/imgSettings1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:onClick="openSettings"
            android:padding="8dp"
            android:scaleType="centerCrop"
            android:src="@drawable/setting_icon" />

    </com.google.android.material.card.MaterialCardView>


    <com.google.android.material.button.MaterialButton
        android:id="@+id/B1"
        android:layout_width="166dp"
        android:layout_height="64dp"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/amaticsc_bold"
        android:onClick="openHistory"
        android:text="History"
        android:textColor="@color/light_blue"

        android:textSize="30sp"
        app:backgroundTint="@color/dark_blue"
        app:cornerRadius="9dp"
        app:layout_constraintEnd_toStartOf="@+id/guideline4"
        app:layout_constraintStart_toStartOf="@+id/guideline5"
        app:layout_constraintTop_toBottomOf="@+id/B3" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/B2"
        android:layout_width="166dp"
        android:layout_height="64dp"
        android:layout_marginTop="50dp"
        android:fontFamily="@font/amaticsc_bold"
        android:onClick="openStatus"
        android:text="status"
        android:textColor="@color/light_blue"
        android:textSize="30sp"

        app:backgroundTint="@color/dark_blue"
        app:cornerRadius="9dp"
        app:layout_constraintEnd_toStartOf="@+id/guideline4"
        app:layout_constraintStart_toStartOf="@+id/guideline5"
        app:layout_constraintTop_toBottomOf="@+id/B1" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/B3"
        android:layout_width="166dp"
        android:layout_height="64dp"
        android:fontFamily="@font/amaticsc_bold"
        android:onClick="openGame"
        android:text="play"
        android:textColor="@color/dark_blue"
        android:textSize="30sp"
        app:backgroundTint="@color/light_blue"
        app:cornerRadius="9dp"
        app:layout_constraintEnd_toStartOf="@+id/guideline4"
        app:layout_constraintStart_toStartOf="@+id/guideline5"
        app:layout_constraintTop_toTopOf="@+id/guideline" />

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imgYoutubeContainer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/off_white"
            app:cornerRadius="50dp"
            app:strokeColor="@color/off_white">

            <ImageView

                android:id="@+id/imgYoutube"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:onClick="openYoutube"
                android:scaleType="fitXY"
                android:src="@drawable/youtube_icon" />

        </com.google.android.material.card.MaterialCardView>


        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imgFacebookContainer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/off_white"
            app:cornerRadius="50dp"
            app:strokeColor="@color/off_white">

            <ImageView
                android:id="@+id/imgFacebook"
                android:layout_width="match_parent"
                android:layout_height="65dp"
                android:onClick="openFacebook"
                android:scaleType="centerCrop"
                android:src="@drawable/facebook_icon" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/imgInstagramContainer"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_margin="2dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            app:cardBackgroundColor="@color/off_white"
            app:cornerRadius="50dp"
            app:strokeColor="@color/off_white">

            <ImageView
                android:id="@+id/imgInstagram"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:padding="0dp"
                android:onClick="openInstagram"
                android:scaleType="centerInside"
                android:src="@drawable/instagram_icon" />

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.39" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline4"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.7" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/guideline5"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.3" />

    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="104dp"
        android:fontFamily="@font/amaticsc_bold"
        android:shadowColor="@color/light_blue"
        android:shadowDx="5"
        android:shadowDy="5"
        android:shadowRadius="7"
        android:text="SUDOKU"
        android:textColor="@color/dark_blue"


        android:textSize="95sp"
        app:layout_constraintBottom_toTopOf="@+id/B3"
        app:layout_constraintEnd_toStartOf="@+id/guideline4"
        app:layout_constraintStart_toStartOf="@+id/guideline5"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.634" />

</androidx.constraintlayout.widget.ConstraintLayout>